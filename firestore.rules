rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own data
    match /cards/{cardId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
    
    // Allow public read for public cards
    match /cards/{cardId} {
      allow read: if resource.data.is_public == true;
    }
    
    // Profiles - users can read public profiles, write own
    match /profiles/{userId} {
      allow read: if true; // Public profiles
      allow write: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }
    
    // Collections - owner and collaborators can access
    match /collections/{collectionId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.user_id || 
        request.auth.uid in (resource.data.collaborators || [])
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
    
    // RSS feeds - owner only
    match /rss_feeds/{feedId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow write: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
  }
}
