{
  "manifest_version": 3,
  "name": "hobt0 - Knowledge Archive",
  "version": "1.0.0",
  "description": "One-click save any webpage to your hobt0 knowledge archive",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://hobt0.tech/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
